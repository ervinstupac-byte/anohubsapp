# Normalize line endings across all platforms.
# WHY: without this, Windows checkouts (core.autocrlf=true) rewrite CRLF on every
# file, producing massive phantom "changes" (e.g. a 774-file churn) that conflict
# with branches authored on macOS/Linux. `text=auto eol=lf` makes LF the canonical
# in-repo ending; Git still hands CRLF to tools/scripts that require it via the
# explicit rules below.
* text=auto eol=lf

# Explicitly treat common binaries as binary (never line-ending converted).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.mp4 binary
*.webm binary
*.glb binary
*.gltf binary

# Platform-specific scripts must keep their native endings.
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
